{
  "name": "hoozit",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "postbuild": "cp -r dist/hoozit/browser/en-US/assets dist/hoozit/browser/assets && cp -r dist/hoozit/browser/en-US/app-icons dist/hoozit/browser/app-icons && cp -r dist/hoozit/browser/en-US/media dist/hoozit/browser/media && rm -rf dist/hoozit/browser/*/assets dist/hoozit/browser/*/app-icons dist/hoozit/browser/*/media"
  },
  "private": true,
  "packageManager": "pnpm@10.4.1",
  "dependencies": {
    "@angular/aria": "^21.2.10",
    "@angular/cdk": "^21.2.10",
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-browser-dynamic": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@angular/service-worker": "^21.2.12",
    "leaflet": "^1.9.4",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^21.2.11",
    "@angular/cli": "^21.2.11",
    "@angular/compiler-cli": "^21.2.12",
    "@angular/localize": "^21.2.12",
    "@types/leaflet": "^1.9.21",
    "@vitest/coverage-v8": "^4.1.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "vitest": "^4.1.6"
  }
}
